{
  "appId": "fi.findjobsinfinland.app",
  "appName": "JobsInFinland",
  "webDir": "www",
  "server": {
    "url": "https://findjobsinfinland.fi/",
    "androidScheme": "https",
    "cleartext": false,
    "allowNavigation": [
      "findjobsinfinland.fi",
      "*.findjobsinfinland.fi",
      "localhost"
    ]
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 10000,
      "launchAutoHide": false,
      "launchFadeOutDuration": 0,
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER",
      "showSpinner": false,
      "splashFullScreen": false,
      "splashImmersive": false
    },
    "Browser": {
      "presentationStyle": "fullscreen"
    }
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#00000000",
    "overrideUserAgent": "FindJobsFinlandApp/1.0 (Android)"
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#ffffff",
    "overrideUserAgent": "FindJobsFinlandApp/1.0 (iOS)",
    "allowsLinkPreviewEnabled": false
  }
}
