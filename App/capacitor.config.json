{
  "appId": "fi.findjobsinfinland.app",
  "appName": "Find Jobs In Finland",
  "webDir": "www",
  "server": {
    "url": "https://findjobsinfinland.fi/",
    "androidScheme": "https",
    "cleartext": false,
    "allowNavigation": [
      "findjobsinfinland.fi",
      "*.findjobsinfinland.fi"
    ],
    "errorPath": "nointernet.html"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 10000,
      "launchAutoHide": false,
      "launchFadeOutDuration": 300,
      "backgroundColor": "#ffffff",
      "androidSplashResourceName": "splash",
      "androidScaleType": "CENTER_INSIDE",
      "showSpinner": true,
      "androidSpinnerStyle": "large",
      "iosSpinnerStyle": "large",
      "spinnerColor": "#482dff",
      "splashFullScreen": false,
      "splashImmersive": false
    },
    "Browser": {
      "presentationStyle": "fullscreen"
    }
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#ffffff",
    "overrideUserAgent": "FindJobsFinlandApp/1.0 (Android)"
  },
  "ios": {
    "contentInset": "always",
    "backgroundColor": "#ffffff",
    "overrideUserAgent": "FindJobsFinlandApp/1.0 (iOS)",
    "allowsLinkPreviewEnabled": false
  }
}
