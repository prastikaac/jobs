# Copy this file to .env and fill in your values
# Never commit the actual .env file to git

# Path to Firebase service account key
FIREBASE_CREDENTIALS_PATH=serviceAccountKey.json

# Public GitHub Pages base URL (no trailing slash)
GITHUB_PAGES_BASE_URL=https://findjobinfinland.fi

# How many days before a job is considered expired
EXPIRATION_DAYS=30

# Scraping limits
MAX_PAGES=10
REQUEST_DELAY_SECONDS=2.0
DETAIL_DELAY_SECONDS=1.5
